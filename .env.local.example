# Resend (for contact form emails) — sign up at resend.com
RESEND_API_KEY=re_...

# The email address that receives contact form submissions
CONTACT_EMAIL=your@email.com

# Stripe (for checkout) — find these in your Stripe dashboard
STRIPE_SECRET_KEY=sk_live_...

# Price of a scarf in cents (e.g. 3500 = $35.00)
SCARF_PRICE_CENTS=3500

# Your deployed site URL (no trailing slash)
NEXT_PUBLIC_BASE_URL=https://wrappedinhislove.com
